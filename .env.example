# Core Settings
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
MOCK_GCP=True

# Firestore
FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION_CHUNKS=rag_chunks
FIRESTORE_COLLECTION_DOCUMENTS=rag_documents

# Document AI
DOCAI_PROCESSOR_ID=your-layout-parser-processor-id

# Vertex AI Models
VERTEX_TEXT_EMBED_MODEL=text-embedding-005
VERTEX_GEMINI_MODEL=gemini-2.5-pro
VERTEX_GEMINI_LOCATION=global

# Vertex AI Vector Search
VERTEX_VECTOR_ENDPOINT_ID=your-vector-endpoint-id
VERTEX_VECTOR_INDEX_ID_NAIVE=your-naive-index-id
VERTEX_VECTOR_INDEX_ID_SEMANTIC=your-semantic-index-id
VERTEX_VECTOR_DEPLOYED_INDEX_ID_NAIVE=your-naive-deployed-index-id
VERTEX_VECTOR_DEPLOYED_INDEX_ID_SEMANTIC=your-semantic-deployed-index-id
